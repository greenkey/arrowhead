{
  "name": "arrowhead-obsidian-plugin",
  "version": "1.0.17",
  "description": "Convert your vault to a complete static website with customizable themes and export options.",
  "main": "main.js",
  "type": "module",
  "files": [
    "main.js",
    "manifest.json",
    "styles.css"
  ],
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "release": "npm run build && zip -r release.zip main.js manifest.json styles.css",
    "release:prepare": "node scripts/release-prepare.mjs",
    "release:commit": "node scripts/release-commit.mjs",
    "deploy": "node scripts/deploy.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint 'src/**/*.{ts,mts,js}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:quiet": "vitest run --silent",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:quiet": "vitest run --config vitest.integration.config.ts --silent",
    "test:all": "npm run test"
  },
  "keywords": [
    "obsidian",
    "static-site-generator",
    "export",
    "publish",
    "website"
  ],
  "author": "Arrowhead",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.1.0",
    "@microsoft/eslint-plugin-sdl": "^1.1.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^4.0.18",
    "esbuild": "^0.20.0",
    "eslint": "^9.39.4",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "obsidian": "^1.5.0"
  }
}
