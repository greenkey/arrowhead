{
  "name": "arrowhead-obsidian-plugin",
  "version": "1.0.0",
  "description": "Convert your Obsidian vault to a complete static website with customizable themes and export options.",
  "main": "main.js",
  "type": "module",
  "files": [
    "main.js",
    "manifest.json",
    "styles.css"
  ],
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "release": "npm run build && zip -r release.zip main.js manifest.json styles.css",
    "release:forgejo": "node scripts/forgejo-release.mjs",
    "deploy": "node scripts/deploy.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:quiet": "vitest run --silent",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:quiet": "vitest run --config vitest.integration.config.ts --silent",
    "test:all": "npm run test"
  },
  "keywords": [
    "obsidian",
    "static-site-generator",
    "export",
    "publish",
    "website"
  ],
  "author": "Arrowhead",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^4.0.18",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "obsidian": "^1.5.0"
  }
}
